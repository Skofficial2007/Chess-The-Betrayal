# ======================================================================
# UNITY CHESS GAME — .gitattributes
# Stack: Unity (PC + Android), Netcode for GameObjects, AI/ML-Agents
# Prepared for: Solo -> Open Source transition
# NOTE: No inline comments allowed in .gitattributes syntax.
#       All comments must be on their own dedicated line.
# ======================================================================


# ----------------------------------------------------------------------
# [1] DEFAULT — Auto-detect and normalize line endings (LF everywhere)
# This single rule catches anything not explicitly listed below.
# ----------------------------------------------------------------------
* text=auto eol=lf


# ----------------------------------------------------------------------
# [2] UNITY YAML — Smart merge + force LF
# UnityYAMLMerge prevents scene/prefab conflict disasters.
# ----------------------------------------------------------------------
*.mat               merge=unityyamlmerge eol=lf
*.anim              merge=unityyamlmerge eol=lf
*.unity             merge=unityyamlmerge eol=lf
*.prefab            merge=unityyamlmerge eol=lf
*.asset             merge=unityyamlmerge eol=lf
*.meta              merge=unityyamlmerge eol=lf
*.controller        merge=unityyamlmerge eol=lf
*.overrideController merge=unityyamlmerge eol=lf
*.physicsMaterial2D  merge=unityyamlmerge eol=lf
*.physicMaterial    merge=unityyamlmerge eol=lf
*.playable          merge=unityyamlmerge eol=lf
*.signal            merge=unityyamlmerge eol=lf
*.brush             merge=unityyamlmerge eol=lf
*.spriteatlas       merge=unityyamlmerge eol=lf
*.terrainlayer      merge=unityyamlmerge eol=lf
*.lighting          merge=unityyamlmerge eol=lf
*.scenetemplate     merge=unityyamlmerge eol=lf


# ----------------------------------------------------------------------
# [3] SOURCE CODE — Explicit text/LF (prevents CRLF corruption on Windows)
# ----------------------------------------------------------------------
*.cs         text eol=lf
*.js         text eol=lf
*.ts         text eol=lf
# ML-Agents training scripts
*.py         text eol=lf
*.sh         text eol=lf
# Windows batch files require CRLF
*.bat        text eol=crlf


# ----------------------------------------------------------------------
# [4] SHADERS & GPU CODE
# ----------------------------------------------------------------------
*.shader         text eol=lf
*.cginc          text eol=lf
*.hlsl           text eol=lf
*.glsl           text eol=lf
*.compute        text eol=lf
*.vert           text eol=lf
*.frag           text eol=lf
*.geom           text eol=lf
*.shadergraph    text eol=lf
*.shadersubgraph text eol=lf


# ----------------------------------------------------------------------
# [5] CONFIG & DATA FILES
# ----------------------------------------------------------------------
*.json       text eol=lf
*.xml        text eol=lf
*.yaml       text eol=lf
*.yml        text eol=lf
*.toml       text eol=lf
*.ini        text eol=lf
*.csv        text eol=lf
*.tsv        text eol=lf
*.txt        text eol=lf
*.md         text eol=lf
*.markdown   text eol=lf
# Unity assembly definitions
*.asmdef     text eol=lf
*.asmref     text eol=lf
# Unity Input System
*.inputactions text eol=lf


# ----------------------------------------------------------------------
# [6] GIT LFS — Binary & Large Files
# These are stored in LFS, not in the Git object store.
# One-time setup per machine: run  git lfs install
# ----------------------------------------------------------------------

# --- Textures & Images ---
*.jpg        filter=lfs diff=lfs merge=lfs -text
*.jpeg       filter=lfs diff=lfs merge=lfs -text
*.png        filter=lfs diff=lfs merge=lfs -text
*.gif        filter=lfs diff=lfs merge=lfs -text
*.webp       filter=lfs diff=lfs merge=lfs -text
*.psd        filter=lfs diff=lfs merge=lfs -text
*.tga        filter=lfs diff=lfs merge=lfs -text
*.tif        filter=lfs diff=lfs merge=lfs -text
*.tiff       filter=lfs diff=lfs merge=lfs -text
*.bmp        filter=lfs diff=lfs merge=lfs -text
# HDR / Lightmaps
*.exr        filter=lfs diff=lfs merge=lfs -text
# Cubemaps / Skyboxes
*.hdr        filter=lfs diff=lfs merge=lfs -text
*.raw        filter=lfs diff=lfs merge=lfs -text

# Android / GPU compressed textures
*.ktx        filter=lfs diff=lfs merge=lfs -text
*.astc       filter=lfs diff=lfs merge=lfs -text
*.etc2       filter=lfs diff=lfs merge=lfs -text
*.dds        filter=lfs diff=lfs merge=lfs -text
*.pvr        filter=lfs diff=lfs merge=lfs -text

# --- Audio ---
*.mp3        filter=lfs diff=lfs merge=lfs -text
*.ogg        filter=lfs diff=lfs merge=lfs -text
*.wav        filter=lfs diff=lfs merge=lfs -text
*.aiff       filter=lfs diff=lfs merge=lfs -text
*.flac       filter=lfs diff=lfs merge=lfs -text
*.m4a        filter=lfs diff=lfs merge=lfs -text
*.aac        filter=lfs diff=lfs merge=lfs -text
*.wma        filter=lfs diff=lfs merge=lfs -text

# --- Video ---
*.mp4        filter=lfs diff=lfs merge=lfs -text
*.mov        filter=lfs diff=lfs merge=lfs -text
*.avi        filter=lfs diff=lfs merge=lfs -text
*.wmv        filter=lfs diff=lfs merge=lfs -text
*.webm       filter=lfs diff=lfs merge=lfs -text
*.mkv        filter=lfs diff=lfs merge=lfs -text

# --- 3D Models ---
*.fbx        filter=lfs diff=lfs merge=lfs -text
*.obj        filter=lfs diff=lfs merge=lfs -text
*.max        filter=lfs diff=lfs merge=lfs -text
*.blend      filter=lfs diff=lfs merge=lfs -text
# Collada
*.dae        filter=lfs diff=lfs merge=lfs -text
*.3ds        filter=lfs diff=lfs merge=lfs -text
*.ply        filter=lfs diff=lfs merge=lfs -text
*.stl        filter=lfs diff=lfs merge=lfs -text
# Binary glTF
*.glb        filter=lfs diff=lfs merge=lfs -text
# Alembic
*.abc        filter=lfs diff=lfs merge=lfs -text

# --- Fonts ---
*.ttf        filter=lfs diff=lfs merge=lfs -text
*.otf        filter=lfs diff=lfs merge=lfs -text
*.woff       filter=lfs diff=lfs merge=lfs -text
*.woff2      filter=lfs diff=lfs merge=lfs -text

# --- AI / ML-Agents Models ---
# Chess AI inference model - tracked in LFS so contributors get it on clone
*.onnx       filter=lfs diff=lfs merge=lfs -text
# PyTorch checkpoint
*.pt         filter=lfs diff=lfs merge=lfs -text
# Generic ML checkpoint
*.ckpt       filter=lfs diff=lfs merge=lfs -text
*.safetensors filter=lfs diff=lfs merge=lfs -text

# --- Archives & Packages ---
*.zip        filter=lfs diff=lfs merge=lfs -text
*.tar        filter=lfs diff=lfs merge=lfs -text
*.gz         filter=lfs diff=lfs merge=lfs -text
*.7z         filter=lfs diff=lfs merge=lfs -text
*.rar        filter=lfs diff=lfs merge=lfs -text

# --- Native Plugins / Libraries ---
*.dll        filter=lfs diff=lfs merge=lfs -text
*.so         filter=lfs diff=lfs merge=lfs -text
*.dylib      filter=lfs diff=lfs merge=lfs -text
*.a          filter=lfs diff=lfs merge=lfs -text
*.lib        filter=lfs diff=lfs merge=lfs -text


# ----------------------------------------------------------------------
# [7] GITHUB LINGUIST — Open Source presentation on GitHub
# ----------------------------------------------------------------------

[attr]unity-generated linguist-generated=true

Assets/Plugins/** linguist-vendored=true
Assets/Settings&Actions/TextMeshPro/** linguist-vendored=true
Assets/Mirror/** linguist-vendored=true
Assets/Netcode/** linguist-vendored=true
Assets/ML-Agents/** linguist-vendored=true
Packages/** linguist-vendored=true

# Make sure C# is the primary detected language (not HLSL/GLSL)
*.cs                   linguist-language=C#
*.shader               linguist-language=HLSL


# ----------------------------------------------------------------------
# [8] DIFF HELPERS — Human-readable diffs for structured files
# ----------------------------------------------------------------------
*.cs     diff=csharp
*.json   diff=json
*.md     diff=markdown