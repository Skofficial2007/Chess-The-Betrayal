# ======================================================================
# UNITY CHESS GAME — .gitignore
# Stack: Unity (PC + Android), Netcode for GameObjects, AI/ML-Agents
# Prepared for: Solo → Open Source transition
# ======================================================================


# ----------------------------------------------------------------------
# [1] UNITY CORE — Generated / Cached / Temporary
# ----------------------------------------------------------------------
.utmp/
/[Ll]ibrary/
/[Tt]emp/
/[Oo]bj/
/[Bb]uild/
/[Bb]uilds/
/[Bb]uild[Ss]taging/
/[Ll]ogs/
/[Cc]rashes/
/[Uu]ser[Ss]ettings/
*.log

# Memory & Recording captures (can be huge + sensitive)
/[Mm]emoryCaptures/
/[Rr]ecordings/

# Unity crash report artifact
sysinfo.txt

# Addressables baked output
/[Aa]ssets/[Aa]ddressable[Aa]ssets[Dd]ata/*/*.bin*

# Android streaming assets (auto-generated)
/[Aa]ssets/[Ss]treamingAssets/aa.meta
/[Aa]ssets/[Ss]treamingAssets/aa/*


# ----------------------------------------------------------------------
# [2] SECURITY — Secrets, Keys & Credentials  ★ CRITICAL ★
# Never commit these, even in a private repo
# ----------------------------------------------------------------------

# Generic secret files
.env
.env.*
.env.local
.env.production
secrets.*
*_secrets.*
*.secret
secret_keys.*
api_keys.*
credentials.*

# Android Signing
# Keep your keystore in a password manager, not the repo
*.keystore
*.jks
*.p12
*.sig
release.keystore
debug.keystore
keystore.properties

# Google / Firebase (contains project API keys)
google-services.json
GoogleService-Info.plist

# Huawei AppGallery
agconnect-services.json

# Unity Gaming Services (UGS) — Relay, Lobby, Matchmaker
# Any auto-generated config files with embedded keys:
UnityServicesConfig.json
unity_services_credentials.json

# Unity License files
*.ulf
*.alf

# Certificate files
*.pem
*.cer
*.crt
*.pfx

# SSH keys (should never be here, but just in case)
id_rsa
id_ed25519
*.pub


# ----------------------------------------------------------------------
# [3] AI / ML-AGENTS — Training Artifacts
# (Chess engine training can generate GBs of data)
# ----------------------------------------------------------------------

# ML-Agents training results (run outputs, checkpoints)
/results/
/[Aa]ssets/ML-Agents/results/

# Python virtualenv (if training locally)
venv/
.venv/
__pycache__/
*.py[cod]
*.pyo

# Jupyter notebooks checkpoints
.ipynb_checkpoints/

# Note: Trained .onnx model files should NOT be ignored.
# They are tracked via Git LFS in .gitattributes (see *.onnx entry).


# ----------------------------------------------------------------------
# [4] NETCODE FOR GAMEOBJECTS / UNITY GAMING SERVICES
# ----------------------------------------------------------------------

# Local relay/server config that may contain endpoint secrets
relay-config.json
lobby-config.json
netcode-debug.log

# Profiler captures from multiplayer sessions
/[Pp]rofile[Rr]esults/
*.profilerdata


# ----------------------------------------------------------------------
# [5] BUILD OUTPUTS — PC & Android
# ----------------------------------------------------------------------
*.apk
*.aab
*.app
*.exe
*.x86_64
*.unitypackage
*.unitypackage.meta


# ----------------------------------------------------------------------
# [6] IDE & EDITOR TOOLING
# ----------------------------------------------------------------------

# JetBrains Rider
/[Aa]ssets/Plugins/Editor/JetBrains*
.idea/

# Visual Studio / VS Code
.vs/
.vscode/
.vsconfig
ExportedObj/
.consulo/

# Auto-generated solution/project files (Unity regenerates these)
*.csproj
*.unityproj
*.sln
*.slnx
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db

# Unity3D generated meta stubs for above
*.pidb.meta
*.pdb.meta
*.mdb.meta


# ----------------------------------------------------------------------
# [7] TEST & CI ARTIFACTS
# (Keep test scripts; ignore generated reports)
# ----------------------------------------------------------------------
/[Tt]est[Rr]esults/
*.nunit
*.trx
coverage/
*.coverage
*.coveragexml


# ----------------------------------------------------------------------
# [8] OS GENERATED FILES
# ----------------------------------------------------------------------
# macOS
.DS_Store
.DS_Store?
.Spotlight-V100
.Trashes
._*

# Windows
ehthumbs.db
Thumbs.db
desktop.ini

# Linux
*~

# Crashlytics
crashlytics-build.properties